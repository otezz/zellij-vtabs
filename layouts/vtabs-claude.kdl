// vtabs-claude.kdl — the vtabs sidebar layout whose main pane starts `claude`.
// Used by the `nw` worktree launcher (shell/vtabs-worktree.zsh) to open a
// worktree in a new tab already running Claude Code.
layout {
    pane split_direction="vertical" {
        pane size=28 borderless=true {
            plugin location="file:~/.config/zellij/plugins/zellij-vtabs.wasm" {
                // keep in sync with vtabs.kdl (autogroup_default / autogroup_N)
                // autogroup_default "repo"
            }
        }
        pane command="claude"
    }
    pane size=1 borderless=true {
        plugin location="zellij:status-bar"
    }
}
